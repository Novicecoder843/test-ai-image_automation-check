# ─────────── Server ───────────
PORT=4000
LOG_LEVEL=info
NODE_ENV=development

# ─────────── PostgreSQL (must have pgvector extension) ───────────
# When using the bundled docker-compose, these defaults already work.
PGHOST=localhost
PGPORT=5432
PGUSER=cleaning
PGPASSWORD=cleaning
PGDATABASE=cleaning_poc

# ─────────── Redis ───────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────── Storage ───────────
# Driver: `local` (saves to ./uploads) or `gcs` (Google Cloud Storage)
STORAGE_DRIVER=local
# When STORAGE_DRIVER=local, files are served at PUBLIC_BASE_URL/files/<key>
PUBLIC_BASE_URL=http://localhost:4000

# GCS (only used if STORAGE_DRIVER=gcs)
GCS_BUCKET_NAME=
GCS_BASE_URL=
GOOGLE_APPLICATION_CREDENTIALS=

# ─────────── AI — CLIP embedder ───────────
# CLIP model used for image embeddings (do NOT add quotes or # comments).
CLIP_MODEL_NAME=Xenova/clip-vit-base-patch32

# ─────────── AI — Vision provider ───────────
# Pick which provider runs the cleanliness check: `anthropic` (default) or `openai`.
VISION_PROVIDER=anthropic

# Anthropic Claude (default — used when VISION_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-4-5
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_TIMEOUT_MS=45000
ANTHROPIC_MAX_TOKENS=600

# OpenAI (fallback — used when VISION_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_TIMEOUT_MS=45000

# ─────────── Rule engine thresholds (cosine similarity 0..1) ───────────
CLEANING_SIMILARITY_PASS_THRESHOLD=0.85
CLEANING_SIMILARITY_FAIL_THRESHOLD=0.65

# ─────────── Worker ───────────
# When true, the API process also runs the BullMQ worker (handy in dev).
RUN_WORKER_IN_API=true
WORKER_CONCURRENCY=2

# ─────────── Image preprocessing (sharp) ───────────
# Longest-side cap in pixels. CLIP downsamples to 224 anyway, but ~1024
# keeps GPT-4o Vision detail high while cutting upload/storage ~15x.
IMG_MAX_DIMENSION=1024
# Output container after preprocessing: jpeg (universal) or webp (smaller).
IMG_OUTPUT_FORMAT=jpeg
# Encoder quality 1-100 (80 is the photo-content sweet spot).
IMG_OUTPUT_QUALITY=80
# Hard cap on decoded pixel count (decompression-bomb defence).
IMG_DECODE_PIXEL_LIMIT=50000000
# Accept HEIC/HEIF uploads from iPhones (transcoded via libheif).
IMG_ALLOW_HEIC=true
# Max raw upload size (MB). 15 MB covers most 12 MP phone JPEG/HEIC.
IMG_MAX_UPLOAD_MB=15

# ─────────── Image quality gate ───────────
IMG_QUALITY_ENFORCE=true
IMG_QUALITY_MIN_DIMENSION=480
IMG_QUALITY_MIN_MEGAPIXELS=0.3
IMG_QUALITY_MIN_SHARPNESS=1
IMG_QUALITY_MIN_BRIGHTNESS=25
IMG_QUALITY_MAX_BRIGHTNESS=235
IMG_QUALITY_MIN_ENTROPY=2.5
IMG_QUALITY_MIN_BYTES=15000

# ─────────── Scene / task matching ───────────
# Reject wrong-area photos (corridor task + kitchen photo → 422)
SCENE_MATCH_ENFORCE=true
SCENE_MATCH_MIN_SIMILARITY=0.88
SCENE_MATCH_STRICT_TEMPLATE=true

# ─────────── Vision cleanliness score thresholds (0..100) ───────────
CLEANING_VISION_PASS_SCORE=80
CLEANING_VISION_FAIL_SCORE=50
CLEANING_VISION_REVIEW_SCORE=65
CLEANING_SCENE_WEIGHT=0.3
CLEANING_CLEANLINESS_WEIGHT=0.7
