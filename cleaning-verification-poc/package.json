{
  "name": "cleaning-verification-poc",
  "version": "1.0.0",
  "description": "Standalone POC for AI facility-cleaning verification (CLIP + GPT-4o Vision + pgvector + BullMQ)",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/workers/start.ts",
    "start": "tsx src/index.ts",
    "start:worker": "tsx src/workers/start.ts",
    "build": "tsc --noEmit",
    "migrate": "tsx src/db/migrate.ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.14.0",
    "@google/genai": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "bullmq": "^5.34.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "p-limit": "^6.2.0",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "sharp": "^0.32.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
